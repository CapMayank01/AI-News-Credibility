# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/news_credibility
SQLALCHEMY_ECHO=False

# API Configuration
API_TITLE=AI-Powered News Credibility Assessment
API_VERSION=1.0.0
DEBUG=True

# Model Configuration
MODEL_PATH=./ml_models/distilbert_model_best.pt
TOKENIZER_PATH=./ml_models/distilbert_tokenizer
CLICKBAIT_MODEL_PATH=./ml_models/clickbait_model.joblib
CLICKBAIT_VECTORIZER_PATH=./ml_models/clickbait_tfidf.joblib
FAISS_INDEX_PATH=./faiss_index/trusted_articles_index.faiss
FAISS_ARTICLES_PATH=./faiss_index/trusted_articles.pkl
EMBEDDER_MODEL=all-MiniLM-L6-v2

# ML Configuration
MAX_SEQUENCE_LENGTH=512
BATCH_SIZE=32
DEVICE=cpu

# Security
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600

# Source Credibility Database
SOURCE_CREDIBILITY_PATH=./backend/app/data/source_credibility.json
